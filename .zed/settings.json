// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
	"formatter": [{ "external": { "command": "dprint", "arguments": ["fmt", "--stdin", "{buffer_path}"] } }],
	"prettier": { "allowed": false },
	"languages": {
		"TypeScript": { "language_servers": ["tsgo", "vtsls", "eslint", "!tailwindcss-intellisense-css"] },
		"JavaScript": { "language_servers": ["tsgo", "vtsls", "eslint"] },
		"CSS": { "language_servers": ["tailwindcss-intellisense-css"] }
	},
	"lsp": {}
}
