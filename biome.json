{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true, "defaultBranch": "master" },
	"files": { "includes": ["**", "!!**/dist", "!!index.html", "!!**/node_modules"] },
	"formatter": { "enabled": false, "indentStyle": "tab" },
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": { "recommended": true },
			"performance": { "recommended": true },
			"correctness": { "recommended": true },
			"suspicious": { "recommended": true },
			"style": { "recommended": true }
		},
		"domains": {
			"project": "recommended",
			"tailwind": "recommended",
			"test": "recommended",
			"playwright": "recommended",
			"types": "recommended"
		}
	},
	"javascript": { "formatter": { "quoteStyle": "single" } },
	"css": { "parser": { "tailwindDirectives": true }, "assist": { "enabled": true }, "linter": { "enabled": true } },
	"json": { "linter": { "enabled": false }, "formatter": { "enabled": false } },
	"assist": { "enabled": true, "actions": { "source": { "organizeImports": "off" }, "recommended": true } }
}
