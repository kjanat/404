{
	"private": true,
	"scripts": {
		"bd": "rm -rf dist; bun build ./src/*.html --target=browser --outdir dist --production",
		"dev": "bun --watch src/index.html",
		"preview": "bun bd && bun --watch dist/index.html",
		"fmt": "dprint fmt",
		"fmt:check": "dprint check",
		"typecheck": "tsc --noEmit",
		"lint": "bun lint:html && bun lint:css && bun lint:js",
		"lint:css": "stylelint 'src/**/*.css'",
		"lint:html": "htmlhint '**/*.html'",
		"lint:js": "eslint",
		"capture": "bun scripts/capture.ts"
	},
	"devDependencies": {
		"@actions/artifact": "^6.1.0",
		"@actions/github-script": "github:actions/github-script",
		"@eslint/js": "^10.0.1",
		"@types/bun": "latest",
		"bun-plugin-tailwind": "^0.1.2",
		"dprint": "^0.51.1",
		"eslint": "^10.0.2",
		"globals": "^17.3.0",
		"htmlhint": "^1.9.1",
		"jiti": "^2.6.1",
		"playwright": "^1.58.2",
		"playwright-extra": "^4.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"stylelint": "^17.3.0",
		"stylelint-config-standard": "^40.0.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"packageManager": "bun@1.3.9",
	"volta": {
		"node": "25.7.0"
	}
}
